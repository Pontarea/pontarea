import { useState, useEffect } from "react";
import { Button } from "@/components/ui/button";
import { Input } from "@/components/ui/input";
import { Label } from "@/components/ui/label";

interface ContentData {
  [key: string]: any;
}

const AdminPanel = () => {
  const [isAuthenticated, setIsAuthenticated] = useState(false);
  const [password, setPassword] = useState("");
  const [content, setContent] = useState<ContentData>({});
  const [editingSection, setEditingSection] = useState<string | null>(null);
  const [saveMessage, setSaveMessage] = useState("");

  const ADMIN_PASSWORD = "mentor2026"; // Измените на свой пароль!

  // Загрузить контент из localStorage
  useEffect(() => {
    const savedContent = localStorage.getItem("mentorContent");
    if (savedContent) {
      setContent(JSON.parse(savedContent));
    }
  }, []);

  // Проверка пароля
  const handleLogin = (e: React.FormEvent) => {
    e.preventDefault();
    if (password === ADMIN_PASSWORD) {
      setIsAuthenticated(true);
      setPassword("");
    } else {
      alert("Неверный пароль!");
    }
  };

  // Сохранить изменения
  const handleSave = () => {
    localStorage.setItem("mentorContent", JSON.stringify(content));
    setSaveMessage("✅ Сохранено!");
    setTimeout(() => setSaveMessage(""), 3000);
  };

  // Обновить текст
  const updateContent = (section: string, field: string, value: string) => {
    setContent((prev: any) => ({
      ...prev,
      [section]: {
        ...prev[section],
        [field]: value,
      },
    }));
  };

  // Если не аутентифицирован
  if (!isAuthenticated) {
    return (
      <div className="min-h-screen bg-[#0a1628] flex items-center justify-center">
        <div className="bg-white/10 border border-[#d4a853] rounded-lg p-8 max-w-md w-full mx-4">
          <h1 className="text-2xl font-bold text-white mb-6 text-center">
            Admin Panel
          </h1>
          <form onSubmit={handleLogin} className="space-y-4">
            <div>
              <Label htmlFor="password" className="text-white">
                Пароль:
              </Label>
              <Input
                id="password"
                type="password"
                value={password}
                onChange={(e) => setPassword(e.target.value)}
                className="bg-white/5 border-white/20 text-white"
                placeholder="Введите пароль"
              />
            </div>
            <Button
              type="submit"
              className="w-full bg-[#d4a853] text-[#0a1628] hover:bg-[#c49843]"
            >
              Войти
            </Button>
          </form>
          <p className="text-white/50 text-sm mt-4 text-center">
            Для входа в админ-панель введите пароль
          </p>
        </div>
      </div>
    );
  }

  // Админ-панель
  return (
    <div className="min-h-screen bg-[#0a1628] py-12">
      <div className="max-w-6xl mx-auto px-4">
        {/* Заголовок */}
        <div className="flex justify-between items-center mb-8">
          <h1 className="text-3xl font-bold text-white">Admin Panel</h1>
          <Button
            onClick={() => setIsAuthenticated(false)}
            variant="outline"
            className="border-[#d4a853] text-[#d4a853] hover:bg-[#d4a853] hover:text-[#0a1628]"
          >
            Выход
          </Button>
        </div>

        {/* Сообщение о сохранении */}
        {saveMessage && (
          <div className="bg-green-500/20 border border-green-500 text-green-400 p-4 rounded-lg mb-6">
            {saveMessage}
          </div>
        )}

        {/* Вкладки для разных секций */}
        <div className="grid md:grid-cols-2 gap-6 mb-8">
          {/* HERO СЕКЦИЯ */}
          <div className="bg-white/5 border border-white/10 rounded-lg p-6">
            <h2 className="text-xl font-bold text-white mb-4">Hero Секция</h2>
            <div className="space-y-4">
              <div>
                <label className="text-white/70 text-sm">Маленький текст:</label>
                <Input
                  value={content.hero?.smallText || "SEGELN LERNEN"}
                  onChange={(e) =>
                    updateContent("hero", "smallText", e.target.value)
                  }
                  className="bg-white/5 border-white/20 text-white"
                />
              </div>
              <div>
                <label className="text-white/70 text-sm">Заголовок:</label>
                <Input
                  value={content.hero?.title || "MENTOR IN BOAT"}
                  onChange={(e) =>
                    updateContent("hero", "title", e.target.value)
                  }
                  className="bg-white/5 border-white/20 text-white"
                />
              </div>
              <div>
                <label className="text-white/70 text-sm">Подзаголовок:</label>
                <Input
                  value={
                    content.hero?.subtitle || "Kapitänkurse in Kroatien"
                  }
                  onChange={(e) =>
                    updateContent("hero", "subtitle", e.target.value)
                  }
                  className="bg-white/5 border-white/20 text-white"
                />
              </div>
              <div>
                <label className="text-white/70 text-sm">Описание:</label>
                <textarea
                  value={
                    content.hero?.description ||
                    "Die Kurse sind für all diejenigen..."
                  }
                  onChange={(e) =>
                    updateContent("hero", "description", e.target.value)
                  }
                  className="w-full bg-white/5 border border-white/20 text-white rounded p-2 h-24"
                />
              </div>
            </div>
          </div>

          {/* КУРС 1 */}
          <div className="bg-white/5 border border-white/10 rounded-lg p-6">
            <h2 className="text-xl font-bold text-white mb-4">
              Курс 1: Kapitänkurs
            </h2>
            <div className="space-y-4">
              <div>
                <label className="text-white/70 text-sm">Название:</label>
                <Input
                  value={
                    content.course1?.title ||
                    "Kapitänkurs Skipper-Lizenz"
                  }
                  onChange={(e) =>
                    updateContent("course1", "title", e.target.value)
                  }
                  className="bg-white/5 border-white/20 text-white"
                />
              </div>
              <div>
                <label className="text-white/70 text-sm">Цена:</label>
                <Input
                  value={content.course1?.price || "ab €1.500"}
                  onChange={(e) =>
                    updateContent("course1", "price", e.target.value)
                  }
                  className="bg-white/5 border-white/20 text-white"
                />
              </div>
              <div>
                <label className="text-white/70 text-sm">Даты начала:</label>
                <Input
                  value={
                    content.course1?.dates || "02.05.2026 / 26.09.2026"
                  }
                  onChange={(e) =>
                    updateContent("course1", "dates", e.target.value)
                  }
                  className="bg-white/5 border-white/20 text-white"
                />
              </div>
              <div>
                <label className="text-white/70 text-sm">Описание:</label>
                <textarea
                  value={
                    content.course1?.description ||
                    "Intensiver Wochenkurs..."
                  }
                  onChange={(e) =>
                    updateContent("course1", "description", e.target.value)
                  }
                  className="w-full bg-white/5 border border-white/20 text-white rounded p-2 h-24"
                />
              </div>
            </div>
          </div>

          {/* КУРС 2 */}
          <div className="bg-white/5 border border-white/10 rounded-lg p-6">
            <h2 className="text-xl font-bold text-white mb-4">
              Курс 2: Hafenmanöver
            </h2>
            <div className="space-y-4">
              <div>
                <label className="text-white/70 text-sm">Название:</label>
                <Input
                  value={
                    content.course2?.title ||
                    "Aufbaukurs Hafenmanöver"
                  }
                  onChange={(e) =>
                    updateContent("course2", "title", e.target.value)
                  }
                  className="bg-white/5 border-white/20 text-white"
                />
              </div>
              <div>
                <label className="text-white/70 text-sm">Цена:</label>
                <Input
                  value={content.course2?.price || "ab €1.600"}
                  onChange={(e) =>
                    updateContent("course2", "price", e.target.value)
                  }
                  className="bg-white/5 border-white/20 text-white"
                />
              </div>
              <div>
                <label className="text-white/70 text-sm">Даты начала:</label>
                <Input
                  value={
                    content.course2?.dates || "09.05.2026 / 16.05.2026"
                  }
                  onChange={(e) =>
                    updateContent("course2", "dates", e.target.value)
                  }
                  className="bg-white/5 border-white/20 text-white"
                />
              </div>
              <div>
                <label className="text-white/70 text-sm">Описание:</label>
                <textarea
                  value={
                    content.course2?.description ||
                    "Perfektionieren Sie..."
                  }
                  onChange={(e) =>
                    updateContent("course2", "description", e.target.value)
                  }
                  className="w-full bg-white/5 border border-white/20 text-white rounded p-2 h-24"
                />
              </div>
            </div>
          </div>

          {/* ИНСТРУКТОР */}
          <div className="bg-white/5 border border-white/10 rounded-lg p-6">
            <h2 className="text-xl font-bold text-white mb-4">Инструктор</h2>
            <div className="space-y-4">
              <div>
                <label className="text-white/70 text-sm">Биография:</label>
                <textarea
                  value={
                    content.instructor?.bio ||
                    "Als erfahrener Segellehrer..."
                  }
                  onChange={(e) =>
                    updateContent("instructor", "bio", e.target.value)
                  }
                  className="w-full bg-white/5 border border-white/20 text-white rounded p-2 h-24"
                />
              </div>
              <div>
                <label className="text-white/70 text-sm">Цитата:</label>
                <textarea
                  value={
                    content.instructor?.quote ||
                    "Segeln ist mehr als..."
                  }
                  onChange={(e) =>
                    updateContent("instructor", "quote", e.target.value)
                  }
                  className="w-full bg-white/5 border border-white/20 text-white rounded p-2 h-20"
                />
              </div>
            </div>
          </div>

          {/* О НАС */}
          <div className="bg-white/5 border border-white/10 rounded-lg p-6 md:col-span-2">
            <h2 className="text-xl font-bold text-white mb-4">О нас</h2>
            <div className="space-y-4">
              <div>
                <label className="text-white/70 text-sm">Основной текст:</label>
                <textarea
                  value={
                    content.about?.text ||
                    "Als Ihr Mentor bringe ich..."
                  }
                  onChange={(e) =>
                    updateContent("about", "text", e.target.value)
                  }
                  className="w-full bg-white/5 border border-white/20 text-white rounded p-2 h-24"
                />
              </div>
            </div>
          </div>

          {/* IMPRESSUM */}
          <div className="bg-white/5 border border-white/10 rounded-lg p-6 md:col-span-2">
            <h2 className="text-xl font-bold text-white mb-6">📋 Impressum</h2>
            
            {/* КОНТАКТНАЯ ИНФОРМАЦИЯ */}
            <div className="mb-6 pb-6 border-b border-white/10">
              <h3 className="text-lg font-semibold text-[#d4a853] mb-4">Контактная информация</h3>
              <div className="grid md:grid-cols-2 gap-4">
                <div>
                  <label className="text-white/70 text-sm">Имя/Компания:</label>
                  <Input
                    value={content.impressum?.contactName || "Bogdan Zambrovski"}
                    onChange={(e) =>
                      updateContent("impressum", "contactName", e.target.value)
                    }
                    className="bg-white/5 border-white/20 text-white"
                  />
                </div>
                <div>
                  <label className="text-white/70 text-sm">Email:</label>
                  <Input
                    value={content.impressum?.email || "info@mentor-in-boat.de"}
                    onChange={(e) =>
                      updateContent("impressum", "email", e.target.value)
                    }
                    className="bg-white/5 border-white/20 text-white"
                  />
                </div>
                <div>
                  <label className="text-white/70 text-sm">Телефон/WhatsApp:</label>
                  <Input
                    value={content.impressum?.phone || "+49 176 44437667"}
                    onChange={(e) =>
                      updateContent("impressum", "phone", e.target.value)
                    }
                    className="bg-white/5 border-white/20 text-white"
                  />
                </div>
                <div>
                  <label className="text-white/70 text-sm">Адрес:</label>
                  <Input
                    value={content.impressum?.address || "Marina Dalmacija, Sukošan, Kroatien"}
                    onChange={(e) =>
                      updateContent("impressum", "address", e.target.value)
                    }
                    className="bg-white/5 border-white/20 text-white"
                  />
                </div>
              </div>
            </div>

            {/* QUALIFICATIONS - JULEICA */}
            <div className="mb-6 pb-6 border-b border-white/10">
              <h3 className="text-lg font-semibold text-[#d4a853] mb-4">🎖️ Jugendleiter (Juleica)</h3>
              <div className="grid md:grid-cols-2 gap-4">
                <div>
                  <label className="text-white/70 text-sm">Дата выдачи (Ausgestellt):</label>
                  <Input
                    type="date"
                    value={content.impressum?.juleicaDate || "2025-08-06"}
                    onChange={(e) =>
                      updateContent("impressum", "juleicaDate", e.target.value)
                    }
                    className="bg-white/5 border-white/20 text-white"
                  />
                </div>
                <div>
                  <label className="text-white/70 text-sm">Выдана (Ausgestellt durch):</label>
                  <Input
                    value={content.impressum?.juleicaIssuedBy || "Bayerischer Jugendring (K.d.ö.R.)"}
                    onChange={(e) =>
                      updateContent("impressum", "juleicaIssuedBy", e.target.value)
                    }
                    className="bg-white/5 border-white/20 text-white"
                  />
                </div>
                <div>
                  <label className="text-white/70 text-sm">Действительна до (Gültig bis):</label>
                  <Input
                    value={content.impressum?.juleicaValidUntil || "Ende August 2028"}
                    onChange={(e) =>
                      updateContent("impressum", "juleicaValidUntil", e.target.value)
                    }
                    className="bg-white/5 border-white/20 text-white"
                  />
                </div>
                <div>
                  <label className="text-white/70 text-sm">Описание:</label>
                  <Input
                    value={content.impressum?.juleicaDescription || "Bescheinigung über in der Jugendarbeit erworbene Qualifikationen"}
                    onChange={(e) =>
                      updateContent("impressum", "juleicaDescription", e.target.value)
                    }
                    className="bg-white/5 border-white/20 text-white"
                  />
                </div>
              </div>
            </div>

            {/* QUALIFICATIONS - VERFAHRENSBEISTAND */}
            <div className="mb-6">
              <h3 className="text-lg font-semibold text-[#d4a853] mb-4">⚖️ Zertifizierter Verfahrensbeistand nach § 158 FamFG</h3>
              <div className="grid md:grid-cols-2 gap-4">
                <div>
                  <label className="text-white/70 text-sm">Дата выдачи (Ausgestellt):</label>
                  <Input
                    type="date"
                    value={content.impressum?.verfahrenDate || "2025-08-13"}
                    onChange={(e) =>
                      updateContent("impressum", "verfahrenDate", e.target.value)
                    }
                    className="bg-white/5 border-white/20 text-white"
                  />
                </div>
                <div>
                  <label className="text-white/70 text-sm">Выдана (Ausgestellt durch):</label>
                  <Input
                    value={content.impressum?.verfahrenIssuedBy || "Investment Zukunft"}
                    onChange={(e) =>
                      updateContent("impressum", "verfahrenIssuedBy", e.target.value)
                    }
                    className="bg-white/5 border-white/20 text-white"
                  />
                </div>
                <div>
                  <label className="text-white/70 text-sm">Действительна до (Gültig bis):</label>
                  <Input
                    type="date"
                    value={content.impressum?.verfahrenValidUntil || "2025-08-13"}
                    onChange={(e) =>
                      updateContent("impressum", "verfahrenValidUntil", e.target.value)
                    }
                    className="bg-white/5 border-white/20 text-white"
                  />
                </div>
                <div>
                  <label className="text-white/70 text-sm">Часов обучения (Unterrichtsstunden):</label>
                  <Input
                    value={content.impressum?.verfahrenHours || "258"}
                    onChange={(e) =>
                      updateContent("impressum", "verfahrenHours", e.target.value)
                    }
                    className="bg-white/5 border-white/20 text-white"
                  />
                </div>
              </div>
              <div className="mt-4">
                <label className="text-white/70 text-sm">Описание:</label>
                <textarea
                  value={content.impressum?.verfahrenDescription || "Zertifizierte Ausbildung zum Verfahrensbeistand mit bestandener Abschlussprüfung"}
                  onChange={(e) =>
                    updateContent("impressum", "verfahrenDescription", e.target.value)
                  }
                  className="w-full bg-white/5 border border-white/20 text-white rounded p-2 h-16"
                />
              </div>
            </div>
          </div>
        </div>

        {/* Кнопка сохранения */}
