{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "sandbox-website-template",
  "compatibility_date": "2025-10-08",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "main": "./src/api/index.ts",
  "observability": {
    "enabled": true
  },
  "upload_source_maps": true,
  "assets": {
    "directory": "./dist/client",
    "not_found_handling": "single-page-application",
    "run_worker_first": [
      "/api/*"
    ]
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "d7nkbo0doix98hosyyy9w6lu2uwpcpr2",
      "database_id": "462c3007-a6c0-4173-9467-ed8ef45b7cb5",
      "migrations_dir": "src/api/migrations"
    }
  ],
  "r2_buckets": [
    {
      "bucket_name": "d7nkbo0doix98hosyyy9w6lu2uwpcpr2",
      "binding": "BUCKET"
    }
  ],
  "vars": {
    "SITE_URL": "https://pontarea.de"
  }
}